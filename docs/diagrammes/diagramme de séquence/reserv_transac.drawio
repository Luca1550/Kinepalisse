<mxfile host="65bd71144e">
    <diagram id="5EY1Lp2LcRnm2H-Wtt-o" name="Page-1">
        <mxGraphModel dx="1673" dy="1646" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    autonumber\n    actor C as Client\n    participant Vue as Composant Réservation (Angular)\n    participant Inter as Intercepteur HTTP (Angular)\n    participant Ctrl as ReservationController (C#)\n    participant Srv as ReservationService (C#)\n    participant DB as Base de Données (MySQL)\n\n    C-&gt;&gt;Vue: Valide le panier et saisit sa carte bancaire\n    Vue-&gt;&gt;Inter: POST /api/reservations {ReservationDto}\n    \n    note over Inter: Sécurité Stateless\n    Inter-&gt;&gt;Inter: Récupère le Token JWT du LocalStorage\n    Inter-&gt;&gt;Inter: Ajoute le header \&quot;Authorization: Bearer [Token]\&quot;\n    Inter-&gt;&gt;Ctrl: Envoie la requête HTTP sécurisée\n    \n    Ctrl-&gt;&gt;Srv: TraiterCommande(ReservationDto)\n    \n    note over Srv,DB: 1. Vérification métier (Places)\n    Srv-&gt;&gt;DB: SELECT SUM(nb_places) FROM Reservation WHERE id_seance = X\n    DB--&gt;&gt;Srv: Retourne le nombre de places déjà vendues\n    \n    alt Places insuffisantes\n        Srv--&gt;&gt;Ctrl: Retourne erreur \&quot;Capacité dépassée\&quot;\n        Ctrl--&gt;&gt;Inter: HTTP 400 (Bad Request)\n        Inter--&gt;&gt;Vue: Propage l&#39;erreur\n        Vue--&gt;&gt;C: Affiche \&quot;Désolé, plus assez de places\&quot;\n    else Places disponibles\n        note over Srv,DB: 2. Début de la Transaction ACID\n        Srv-&gt;&gt;DB: BEGIN TRANSACTION\n        \n        note over Srv: 3. Logique Financière\n        Srv-&gt;&gt;Srv: Simule le traitement du paiement bancaire\n        \n        alt Paiement Refusé\n            Srv-&gt;&gt;DB: ROLLBACK (Annule tout)\n            Srv--&gt;&gt;Ctrl: Retourne erreur \&quot;Paiement échoué\&quot;\n            Ctrl--&gt;&gt;Inter: HTTP 402 (Payment Required)\n            Inter--&gt;&gt;Vue: Propage l&#39;erreur\n            Vue--&gt;&gt;C: Affiche \&quot;Paiement refusé\&quot;\n        else Paiement Accepté\n            note over Srv,DB: 4. Persistance des données\n            Srv-&gt;&gt;DB: INSERT INTO Reservation (...)\n            Srv-&gt;&gt;DB: INSERT INTO Paiement (...)\n            Srv-&gt;&gt;DB: COMMIT (Valide définitivement)\n            \n            Srv--&gt;&gt;Ctrl: Retourne l&#39;objet Reservation créé\n            Ctrl--&gt;&gt;Inter: HTTP 201 (Created) + Données\n            Inter--&gt;&gt;Vue: Renvoie la confirmation\n            Vue--&gt;&gt;C: Affiche le Billet / Redirige vers Historique\n        end\n    end\n&quot;&#xa;}" id="2">
                    <mxCell style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" vertex="1" parent="1">
                        <mxGeometry x="-700" y="-720" width="2226.5" height="1954" as="geometry"/>
                    </mxCell>
                </UserObject>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>